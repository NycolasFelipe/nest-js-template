PORT=3000

# Defina como false para subir a API sem conectar no banco.
# Em ambiente de teste (NODE_ENV=test), o banco já é desabilitado automaticamente.
DB_ENABLED=true

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_RETRY_ATTEMPTS=3
DB_RETRY_DELAY=1000
